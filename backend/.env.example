# Copy this file to .env and fill in the values before running the server.
# Never commit the actual .env file to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/famex

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# JWT verification: The backend auto-fetches JWKS from SUPABASE_URL for ES256.
# Only needed if your Supabase project still uses HS256 (legacy):
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Google Gemini
# ---------------------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>

# ---------------------------------------------------------------------------
# CORS  (comma-separated list of allowed origins, or ["*"] for development)
# ---------------------------------------------------------------------------
CORS_ORIGINS=["*"]

# ---------------------------------------------------------------------------
# Runtime environment  (development | staging | production)
# ---------------------------------------------------------------------------
ENV=development
